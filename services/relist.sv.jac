node Item {
    has description: str = "";
    has item_type: str = "";
    has brand: str = "";
    has model: str = "";
    has condition: str = "";
    has size: str = "";
}

node MarketData {
    has active_listings: list[dict] = [];
    has avg_price: float = 0.0;
    has price_low: float = 0.0;
    has price_high: float = 0.0;
    has num_results: int = 0;
}

node Pricing {
    has recommended_price: float = 0.0;
    has strategy: str = "competitive";
    has reasoning: str = "";
}

node Listing {
    has title: str = "";
    has description: str = "";
    has category_id: str = "11450";
    has condition_id: str = "3000";
    has item_specifics: dict = {};
}

node Published {
    has status: str = "draft";
    has url: str = "";
    has next_step: str = "";
    has item_id: str = "";
}

def infer_brand(text: str) -> str {
    lower = text.lower();
    if "nike" in lower { return "Nike"; }
    if "adidas" in lower { return "Adidas"; }
    if "apple" in lower { return "Apple"; }
    if "sony" in lower { return "Sony"; }
    return "Unknown";
}

def infer_condition(text: str) -> str {
    lower = text.lower();
    if "new" in lower or "brand new" in lower { return "New"; }
    if "worn" in lower or "used" in lower or "preowned" in lower { return "Used"; }
    return "Used";
}

def infer_size(text: str) -> str {
    lower = text.lower();
    for token in lower.split(" ") {
        if token.isdigit() { return token; }
    }
    return "";
}

def infer_item_type(text: str) -> str {
    lower = text.lower();
    if "dunk" in lower or "shoe" in lower or "sneaker" in lower { return "Sneakers"; }
    if "iphone" in lower or "laptop" in lower or "camera" in lower { return "Electronics"; }
    return "General";
}

def build_mock_market(item: Item) -> MarketData {
    listings = [
        {"title": item.brand + " resale comp A", "price": 118.0, "condition": item.condition},
        {"title": item.brand + " resale comp B", "price": 126.0, "condition": item.condition},
        {"title": item.brand + " resale comp C", "price": 134.0, "condition": item.condition},
        {"title": item.brand + " resale comp D", "price": 142.0, "condition": item.condition}
    ];
    prices = [118.0, 126.0, 134.0, 142.0];
    return MarketData(
        active_listings=listings,
        avg_price=sum(prices) / len(prices),
        price_low=min(prices),
        price_high=max(prices),
        num_results=len(listings)
    );
}

def build_pricing(item: Item, market: MarketData) -> Pricing {
    recommended = market.avg_price - 4.0;
    strategy = "competitive";
    if item.condition == "New" {
        recommended = market.avg_price + 8.0;
        strategy = "premium";
    }
    return Pricing(
        recommended_price=recommended,
        strategy=strategy,
        reasoning="Template mode uses mock comps. Once keys are added, this step can switch to live eBay research plus by llm() pricing."
    );
}

def build_listing(item: Item, pricing: Pricing) -> Listing {
    title = (item.brand + " " + item.model + " " + item.item_type + " Size " + item.size + " " + item.condition).strip();
    if not title { title = item.description; }
    return Listing(
        title=title[:80],
        description="Autogenerated draft for: " + item.description + ". Recommended list price is $" + str(round(pricing.recommended_price, 2)) + ". Add photos, shipping details, and platform-specific specifics before publishing.",
        category_id="15709" if item.item_type == "Electronics" else "11450",
        condition_id="1000" if item.condition == "New" else "3000",
        item_specifics={
            "Brand": item.brand,
            "Model": item.model,
            "Condition": item.condition,
            "Size": item.size
        }
    );
}

def build_publish_state(use_live_publish: bool) -> Published {
    if use_live_publish {
        return Published(
            status="ready",
            url="https://developer.ebay.com/",
            next_step="Add eBay sandbox credentials and switch the publish helper to live API calls.",
            item_id="sandbox-pending"
        );
    }
    return Published(
        status="draft",
        url="",
        next_step="Template mode only. Add Anthropic and eBay keys later to enable real publishing.",
        item_id=""
    );
}

def:pub run_relist_agent(user_input: str, use_live_publish: bool = False) -> dict {
    item = Item(
        description=user_input,
        item_type=infer_item_type(user_input),
        brand=infer_brand(user_input),
        model="Dunk Low" if "dunk" in user_input.lower() else "",
        condition=infer_condition(user_input),
        size=infer_size(user_input)
    );

    market = build_mock_market(item);
    pricing = build_pricing(item, market);
    listing = build_listing(item, pricing);
    published = build_publish_state(use_live_publish);

    return {
        "item": {
            "description": item.description,
            "item_type": item.item_type,
            "brand": item.brand,
            "model": item.model,
            "condition": item.condition,
            "size": item.size
        },
        "market_research": {
            "avg_price": market.avg_price,
            "price_range": [market.price_low, market.price_high],
            "num_listings_found": market.num_results,
            "sample_listings": market.active_listings
        },
        "pricing": {
            "recommended_price": pricing.recommended_price,
            "strategy": pricing.strategy,
            "reasoning": pricing.reasoning
        },
        "listing": {
            "title": listing.title,
            "description": listing.description,
            "category_id": listing.category_id,
            "condition_id": listing.condition_id,
            "item_specifics": listing.item_specifics
        },
        "published": {
            "status": published.status,
            "url": published.url,
            "item_id": published.item_id,
            "next_step": published.next_step
        }
    };
}
